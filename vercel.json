{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{static/**,assets/**,plots/**,metricas/**,tests/**,**/test_*.py}"
    }
  }
}